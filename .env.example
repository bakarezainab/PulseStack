# Nomba API Configuration
# Get your credentials from https://dashboard.nomba.com

# Account IDs
VITE_NOMBA_PARENT_ACCOUNT_ID=your-parent-account-id
VITE_NOMBA_SUB_ACCOUNT_ID=your-sub-account-id

# TEST credentials (for development)
VITE_NOMBA_TEST_CLIENT_ID=your-test-client-id
VITE_NOMBA_TEST_PRIVATE_KEY=your-test-private-key

# LIVE credentials (for production)
VITE_NOMBA_LIVE_CLIENT_ID=your-live-client-id
VITE_NOMBA_LIVE_PRIVATE_KEY=your-live-private-key

# Mode: 'test' or 'live'
VITE_NOMBA_MODE=test
